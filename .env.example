APP_NAME=PelangLor
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

# ---------------------------------------------------------------
# BROWSERSHOT — Railway/Linux path (diisi otomatis oleh nixpacks)
# ---------------------------------------------------------------
CHROME_PATH=/run/current-system/sw/bin/chromium
NODE_BINARY=node
NPM_BINARY=npm

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---------------------------------------------------------------
# DATABASE — Gunakan variable Railway (dari service MySQL)
# ---------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# ---------------------------------------------------------------
# SESSION — Gunakan database agar tidak hilang saat restart
# ---------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# ---------------------------------------------------------------
# FILESYSTEM — Gunakan public agar gambar berita bisa diakses
# ---------------------------------------------------------------
FILESYSTEM_DISK=public

QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
