APP_NAME=PelangLor
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

# ---------------------------------------------------------------
# BROWSERSHOT (Unduh JPG) — Sesuaikan path sesuai hosting
# Railway/Linux  : CHROME_PATH=/usr/bin/chromium | NODE_BINARY=node | NPM_BINARY=npm
# Hostinger      : tanyakan path chromium ke support hosting
# Windows lokal  : isi path Chrome & Node di laptop Anda
# ---------------------------------------------------------------
CHROME_PATH=/usr/bin/chromium
NODE_BINARY=node
NPM_BINARY=npm

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Sistem Desa Pelang Lor"

# Email Admin (Penerima Notifikasi dari Warga)
MAIL_ADMIN_NOTIFY_ADDRESS=

# SMTP Admin (Pengirim Email ke Warga)
MAIL_ADMIN_SCHEME=smtps
MAIL_ADMIN_HOST=smtp.gmail.com
MAIL_ADMIN_PORT=465
MAIL_ADMIN_USERNAME=
MAIL_ADMIN_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
